# Local development environment — DO NOT COMMIT.
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.

# Your SharePoint Online tenant domain (without https://).
# Example: contoso.sharepoint.com
# This is read by scripts/dev-webpart.sh and passed to the SPFx serve tool,
# which uses it to replace the {tenantdomain} placeholder in config/serve.json.
# Alternatively, set SPFX_SERVE_TENANT_DOMAIN on your host OS (e.g. in ~/.bashrc)
# so the devcontainer picks it up automatically via containerEnv — no .env needed.
SPFX_SERVE_TENANT_DOMAIN=
