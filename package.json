{
  "name": "guest-sponsor-info",
  "version": "0.20.0",
  "description": "SharePoint Online web part that shows the Microsoft Entra sponsors of the signed-in guest user",
  "license": "MIT",
  "author": "Julian Pawlowski",
  "homepage": "https://github.com/workoho/spfx-guest-sponsor-info",
  "keywords": [
    "sharepoint",
    "spfx",
    "sharepoint-framework",
    "microsoft-entra",
    "guest",
    "sponsor",
    "microsoft-graph",
    "webpart"
  ],
  "private": true,
  "engines": {
    "node": ">=22.14.0 < 23.0.0"
  },
  "scripts": {
    "build": "heft test --clean --production && heft package-solution --production",
    "test": "heft test --clean",
    "start": "heft start --clean",
    "clean": "heft clean",
    "eject-webpack": "heft eject-webpack",
    "lint:ts": "eslint src --ext .ts,.tsx",
    "lint:ts:func": "eslint azure-function/src --ext .ts",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:md": "markdownlint-cli2 --config .markdownlint.json README.md AGENTS.md azure-function/README.md docs/**/*.md .github/*.md .github/**/*.md",
    "lint:bicep": "az bicep lint --file azure-function/infra/main.bicep",
    "lint:sh": "shellcheck -x scripts/*.sh azure-function/infra/hooks/*.sh",
    "lint:loc": "node --check src/webparts/guestSponsorInfo/loc/da-dk.js src/webparts/guestSponsorInfo/loc/de-de.js src/webparts/guestSponsorInfo/loc/en-us.js src/webparts/guestSponsorInfo/loc/es-es.js src/webparts/guestSponsorInfo/loc/fi-fi.js src/webparts/guestSponsorInfo/loc/fr-fr.js src/webparts/guestSponsorInfo/loc/it-it.js src/webparts/guestSponsorInfo/loc/ja-jp.js src/webparts/guestSponsorInfo/loc/nb-no.js src/webparts/guestSponsorInfo/loc/nl-nl.js src/webparts/guestSponsorInfo/loc/pl-pl.js src/webparts/guestSponsorInfo/loc/pt-br.js src/webparts/guestSponsorInfo/loc/sv-se.js src/webparts/guestSponsorInfo/loc/zh-cn.js",
    "lint": "npm run lint:ts && npm run lint:ts:func && npm run lint:scss && npm run lint:md && npm run lint:bicep && npm run lint:sh && npm run lint:loc",
    "fix:ts": "eslint src --ext .ts,.tsx --fix",
    "fix:ts:func": "eslint azure-function/src --ext .ts --fix",
    "fix:scss": "stylelint \"src/**/*.scss\" --fix",
    "fix:md": "markdownlint-cli2 --config .markdownlint.json --fix README.md AGENTS.md azure-function/README.md docs/**/*.md .github/*.md .github/**/*.md",
    "fix:json": "prettier --write \"*.{json,jsonc}\" \"config/*.{json,jsonc}\" \"azure-function/*.{json,jsonc}\" \"azure-function/infra/**/*.{json,jsonc}\" \".vscode/*.{json,jsonc}\" \".devcontainer/*.{json,jsonc}\"",
    "fix:sh": "shfmt -w -i 2 -ci scripts/*.sh azure-function/infra/hooks/*.sh",
    "fix": "npm run fix:ts && npm run fix:ts:func && npm run fix:scss && npm run fix:md && npm run fix:json && npm run fix:sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@fluentui/react-components": "9.73.4",
    "@fluentui/react-icons": "2.0.322",
    "@fluentui/react-migration-v8-v9": "9.10.6",
    "@microsoft/sp-component-base": "1.22.2",
    "@microsoft/sp-core-library": "1.22.2",
    "@microsoft/sp-http": "1.22.2",
    "@microsoft/sp-lodash-subset": "1.22.2",
    "@microsoft/sp-office-ui-fabric-core": "1.22.2",
    "@microsoft/sp-property-pane": "1.22.2",
    "@microsoft/sp-webpart-base": "1.22.2",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@microsoft/eslint-config-spfx": "1.22.2",
    "@microsoft/eslint-plugin-spfx": "1.22.2",
    "@microsoft/sp-module-interfaces": "1.22.2",
    "@microsoft/spfx-heft-plugins": "1.22.2",
    "@microsoft/spfx-web-build-rig": "1.22.2",
    "@rushstack/eslint-config": "4.5.2",
    "@rushstack/heft": "1.1.2",
    "@types/heft-jest": "1.0.6",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "~1.18.8",
    "@typescript-eslint/parser": "8.57.1",
    "css-loader": "~7.1.2",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "0.22.0",
    "prettier": "3.8.1",
    "stylelint": "17.5.0",
    "stylelint-config-standard-scss": "17.0.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "@rushstack/heft": "1.1.2"
  },
  "resolutions": {
    "@types/react": "17.0.45"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix",
    "azure-function/src/**/*.ts": "eslint --fix",
    "src/**/*.scss": "stylelint --fix",
    "*.md": "markdownlint-cli2 --fix",
    "**/*.{json,jsonc}": "prettier --write --ignore-path .prettierignore",
    "**/*.sh": "shfmt -w -i 2 -ci"
  }
}
