{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "functionAppName": {
      "value": "${AZURE_FUNCTION_APP_NAME}"
    },
    "tenantId": {
      "value": "${AZURE_TENANT_ID}"
    },
    "tenantName": {
      "value": "${AZURE_SHAREPOINT_TENANT_NAME}"
    },
    "webPartClientId": {
      "value": "${AZURE_WEB_PART_CLIENT_ID}"
    },
    "enableMonitoring": {
      "value": false
    },
    "deployAzureMaps": {
      "value": true
    },
    "azureMapsAccountName": {
      "value": ""
    },
    "defaultAlertNotificationEmail": {
      "value": ""
    },
    "enableFailureAnomaliesAlert": {
      "value": false
    },
    "defaultOperationalActionGroupShortName": {
      "value": "GSIOps"
    },
    "defaultInfoActionGroupShortName": {
      "value": "GSIInfo"
    },
    "hostingPlan": {
      "value": "Consumption"
    },
    "appVersion": {
      "value": "latest"
    },
    "maximumFlexInstances": {
      "value": 10
    }
  }
}
